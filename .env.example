NODE_ENV=development
PORT=3001

# Postgres
POSTGRES_HOST=localhost
POSTGRES_PORT=5434
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=driver_allocation

# Redis
REDIS_HOST=localhost
REDIS_PORT=6380

# Ride allocation timing (see README "Ride lifecycle" section).
# Defaults if unset: OFFER_TIMEOUT_MS=30000 (30s), MAX_SEARCH_DURATION_MS=300000 (5min).
# Uncomment and lower these to iterate faster while testing, e.g.:
# OFFER_TIMEOUT_MS=5000
# MAX_SEARCH_DURATION_MS=15000
